{
  "name": "llm-betting-competition",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/infrastructure/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test:pipeline": "bun run src/scripts/test-pipeline.ts",
    "iterate": "bun run src/scripts/iterate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@openrouter/sdk": "^0.9.11",
    "@polymarket/clob-client": "^5.2.4",
    "drizzle-orm": "^0.45.1",
    "ethers": "^6.16.0",
    "zod": "^4.3.6"
  }
}
