{
  "name": "llm-betting-competition",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:api": "bun run --watch src/index.ts",
    "dev:ui": "cd ui && bun run dev",
    "build:ui": "cd ui && bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/infrastructure/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test:pipeline": "bun run src/scripts/test-pipeline.ts",
    "iterate": "bun run src/scripts/iterate.ts",
    "competitor:add": "bun run src/scripts/add-competitor.ts",
    "discover:tags": "bun run src/scripts/discover-tags.ts",
    "wallets:create": "bun run src/scripts/manage-wallets.ts create",
    "wallets:list": "bun run src/scripts/manage-wallets.ts list",
    "wallets:export": "bun run src/scripts/manage-wallets.ts export",
    "wallets:import": "bun run src/scripts/import-wallets.ts",
    "wallets:remove": "bun run src/scripts/manage-wallets.ts remove",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@openrouter/sdk": "^0.9.11",
    "@polymarket/clob-client": "^5.2.4",
    "drizzle-orm": "^0.45.1",
    "ethers": "^6.16.0",
    "hono": "^4.12.3",
    "zod": "^4.3.6"
  }
}
